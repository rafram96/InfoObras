# ============================================================================
# Alpamayo-InfoObras — Backend Configuration
# ============================================================================
# Copiar este archivo como .env y ajustar los valores segun el entorno.
#   cp .env.example .env
#
# Todas las variables con valor por defecto son opcionales.
# Las marcadas como REQUERIDO deben configurarse antes de iniciar.
# ============================================================================


# ── Base de datos PostgreSQL ────────────────────────────────────────────────
# Formato: postgresql://usuario:password@host:puerto/nombre_db
# Si se usa docker-compose.yml incluido, los valores por defecto funcionan.
DATABASE_URL=postgresql://admin:admin123@localhost:5432/infoobras


# ── Motor-OCR (subprocess) ──────────────────────────────────────────────────
# REQUERIDO: rutas absolutas al motor-OCR en el servidor.
# El motor-OCR se ejecuta como subprocess — este repo NO lo incluye.

# Python del venv del motor-OCR (con PaddleOCR + dependencias GPU)
MOTOR_OCR_PYTHON=D:\proyectos\motor-OCR\venv\Scripts\python.exe

# Script wrapper que el backend invoca como subprocess
MOTOR_OCR_WRAPPER=D:\proyectos\motor-OCR\subprocess_wrapper.py

# ── pdfplumber fast-path ────────────────────────────────────────────────────
# Cuando un PDF es digital (texto nativo), se puede saltar PaddleOCR+Qwen-VL
# y usar el mode "pdfplumber_segmentation" del wrapper, que es mucho mas rapido.

# true = siempre usar motor-OCR completo (desactiva el fast-path globalmente).
# Tambien se puede activar por job via el checkbox "Forzar motor-OCR" del upload.
FORCE_MOTOR_OCR=false

# Umbral de chars/pagina (muestra de 5 primeras paginas) para considerar digital.
# Estricto (200) evita intentos fallidos con PDFs mixtos; relajado (50) maximiza cobertura.
PDFPLUMBER_CHARS_THRESHOLD=200


# ── Directorios de trabajo ──────────────────────────────────────────────────
# Donde se guardan los PDFs subidos por el usuario
UPLOADS_DIR=data/uploads

# Donde el motor-OCR escribe sus resultados (.md)
OUTPUT_DIR=data/ocr_outputs


# ── Ollama (LLM local) ─────────────────────────────────────────────────────
# URL base de Ollama. Por defecto: http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434

# Modelos requeridos (deben estar descargados en Ollama):
#   ollama pull qwen2.5:14b      → extraccion semantica (Pasos 1-3)
#   ollama pull qwen2.5vl:7b     → lectura de tablas escaneadas
QWEN_MODEL=qwen2.5:14b
QWEN_VL_MODEL=qwen2.5vl:7b

# Tokens maximos por respuesta del LLM
QWEN_MAX_TOKENS=8192

# Ventana de contexto (input+output) de Qwen 14B.
# Ollama default es 4096 (TRUNCA prompts largos → causa alucinaciones).
# Recomendaciones por VRAM:
#   16 GB (Quadro RTX 5000): 12288 (default, ~36k chars, ~600 MB KV cache)
#   24 GB+: 16384-32768 (para TDRs muy largos sin truncar)
#   Si hay OOM en GPU: bajar a 8192
QWEN_NUM_CTX=12288

# Timeouts en segundos
QWEN_TIMEOUT=300
QWEN_VL_TIMEOUT=120


# ── CORS ────────────────────────────────────────────────────────────────────
# Origenes permitidos, separados por coma.
# Ajustar segun el dominio/puerto del frontend.
CORS_ORIGINS=http://localhost:3002


# ── Verificaciones externas (Paso 4) ───────────────────────────────────────
# InfoObras se consulta automaticamente. SUNAT y colegios son manuales.

# SUNAT: verificacion manual — tiene CAPTCHA, no se automatiza.
# El evaluador verifica en https://e-consultaruc.sunat.gob.pe

# Colegios profesionales (CIP, CAP, CBP, etc.): verificacion manual.
# Cada colegio tiene portal distinto — no se automatiza.


# ============================================================================
# Docker Compose — variables para los servicios (usadas en docker-compose.yml)
# ============================================================================
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin123
POSTGRES_DB=infoobras

PGADMIN_DEFAULT_EMAIL=admin@infoobras.local
PGADMIN_DEFAULT_PASSWORD=admin123
